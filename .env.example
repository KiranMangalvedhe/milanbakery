# ================================
# Milan Bakery - Environment Config
# ================================
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# Neon PostgreSQL (Free tier at neon.tech)
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx-xxx-xxx.us-east-2.aws.neon.tech/milanbakery?sslmode=require

# App Config
APP_NAME=Milan Bakery
ADMIN_EMAIL=admin@milanbakery.com
ADMIN_PASSWORD=Admin@123
